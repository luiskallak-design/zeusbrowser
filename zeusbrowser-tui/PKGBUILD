# ⌬ [ZEUS-BROWSER] - NÚCLEO DE NAVEGAÇÃO DO ECOSSISTEMA ARCHIA
# Maintainer: luiskallak-design <luiskallak@gmail.com>

pkgname=zeusbrowser-git
pkgver=1.0
pkgrel=1
pkgdesc="Navegador cyberpunk tático com integração feh e suporte a áudio digital"
arch=('x86_64')
url="https://github.com/luiskallak-design/zeusbrowser"
license=('MIT')

# Arsenal de Dependências
depends=('ncurses' 'feh' 'alsa-utils')
makedepends=('git' 'gcc' 'make')
provides=('zeusbrowser')
conflicts=('zeusbrowser')

source=("git+${url}.git")
sha256sums=('SKIP')

build() {
  # Entra na pasta do clone e depois na subpasta onde o Makefile reside
  cd "$srcdir/zeusbrowser/zeusbrowser-tui"
  
  echo -e "\033[0;36m⌬ INICIANDO FORJA DO OBSERVADOR DO OLIMPO...\033[0m"
  make
}

package() {
  # Entra na subpasta para coletar o binário e assets gerados
  cd "$srcdir/zeusbrowser/zeusbrowser-tui"
  
  echo -e "\033[0;32m⌬ DISTRIBUINDO ASSETS E BINÁRIO NO SISTEMA...\033[0m"
  
  # Instalação do Binário Principal do Zeus
  install -Dm755 bin/zeusbrowser "$pkgdir/usr/bin/zeusbrowser"
  
  # Instalação dos Assets Visuais (Temas de Cores)
  mkdir -p "$pkgdir/usr/share/zeusbrowser/assets"
  cp -r assets/* "$pkgdir/usr/share/zeusbrowser/assets/"
}
